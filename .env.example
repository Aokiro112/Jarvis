# ============================================
# JARVIS AI ASSISTANT - ENVIRONMENT CONFIG
# ============================================

# Groq API Key (Get from https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Groq Model (Recommended: llama3-70b-8192 or mixtral-8x7b-32768)
GROQ_MODEL=llama3-70b-8192

# Assistant Name
ASSISTANT_NAME=Jarvis

# Debug Mode (true/false)
DEBUG_MODE=false

# Voice Mode (true/false) - requires microphone
VOICE_MODE=false

# Silent Mode - minimal terminal output
SILENT_MODE=false

# Auto-start on Windows boot (true/false)
AUTO_START=false

# Command History Limit
HISTORY_LIMIT=100

# Screenshot capability (true/false)
SCREENSHOT_ENABLED=true

# Response language
LANGUAGE=en

# Wake word for voice activation
WAKE_WORD=jarvis

# Memory database path
MEMORY_DB_PATH=./memory/jarvis_memory.json

# Logs path
LOGS_PATH=./logs/

# Scheduler enabled
SCHEDULER_ENABLED=true

# Max retries on failed command
MAX_RETRIES=3
